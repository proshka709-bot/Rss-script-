-- [BUG FIX] Добавлена проверка Visible — раньше могла вернуть скрытую кнопку из кэша
local function FindGKButton()
    if cachedGKButton and cachedGKButton.Parent and cachedGKButton.Visible then
        return cachedGKButton
    end
    cachedGKButton = nil  -- инвалидируем устаревший кэш
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return nil end
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("GuiButton") and obj.Name == "GoalieSelect" and obj.Visible then
            cachedGKButton = obj
            return obj
        end
    end
    return nil
end

local function IsRealPlayerOnGoal(side)
    local bools = Workspace:FindFirstChild("Bools")
    if not bools then return false end
    local pg = bools:FindFirstChild(side == "Home" and "HPG" or "APG")
    if not pg or not pg.Value then return false end
    local val = pg.Value
    for _, p in ipairs(Players:GetPlayers()) do
        if p == val and p ~= LocalPlayer then
            return true
        end
    end
    return false
end

local function IsIAmGK()
    local bools = Workspace:FindFirstChild("Bools")
    if not bools then return false end
    local hpg = bools:FindFirstChild("HPG")
    local apg = bools:FindFirstChild("APG")
    if hpg and hpg.Value == LocalPlayer then return true end
    if apg and apg.Value == LocalPlayer then return true end
    return false
end

local function TryJoinGK()
    if IsIAmGK() then return end

    local side = GetMySide()
    if not side then return end

    if IsRealPlayerOnGoal(side) then return end

    local btn = FindGKButton()
    if not btn then return end

    pcall(function()
        for _, conn in ipairs(getconnections(btn.MouseButton1Click)) do conn:Fire() end
        for _, conn in ipairs(getconnections(btn.TouchTap))         do conn:Fire() end
    end)
    CrimsonLib.Notify({ Title = "Авто-ГК", Content = "✅ Зашёл на ворота!", Duration = 2 })
end

-- [УЛУЧШЕНИЕ] Раньше AutoGK работал на Heartbeat (~60 раз/сек) — это лишняя нагрузка.
-- Теперь task.spawn + task.wait: проверяет раз в 0.1-0.2 сек с джиттером
local function StartAutoGK()
    AutoGKRunning = true
    task.spawn(function()
        while AutoGKRunning do
            TryJoinGK()
            -- [УЛУЧШЕНИЕ] Джиттер интервала — анти-бан + меньше нагрузки
            task.wait(Jitter(0.15, 0.3))
        end
    end)
end

