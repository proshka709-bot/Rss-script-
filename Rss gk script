    end)
end

local function LoadConfig()
    local ok, raw = pcall(readfile, CONFIG_FILE)
    if not ok or not raw or raw == "" then return end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or not data then return end
    if data.DiveReactionTime   then Settings.DiveReactionTime  = data.DiveReactionTime  end
    if data.DiveAutoJump       ~= nil then Settings.DiveAutoJump = data.DiveAutoJump    end
    if data.PingCompensation   ~= nil then Settings.PingCompensation = data.PingCompensation end
    if data.DiveMaxDistance    then Settings.DiveMaxDistance   = data.DiveMaxDistance   end
    if data.HitboxSize         then Settings.HitboxSize = Vector3.new(data.HitboxSize, data.HitboxSize, data.HitboxSize) end
    return data
end

