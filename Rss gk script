local function UpdateHitbox(show)
    if RSSHitbox then RSSHitbox:Destroy(); RSSHitbox = nil end
    local root = GetRoot()
    if not root or not show then return end

    RSSHitbox              = Instance.new("BoxHandleAdornment")
    RSSHitbox.Name         = "RSSHitbox"
    RSSHitbox.ZIndex       = 10
    RSSHitbox.Color3       = Color3.fromRGB(0, 255, 100)
    RSSHitbox.Transparency = Settings.HitboxVisible and 0.5 or 0.99
    RSSHitbox.Size         = Settings.HitboxSize
    RSSHitbox.Adornee      = root
    RSSHitbox.Parent       = Workspace.Terrain
end

local function ReachLoop()
    local root = GetRoot()
    local ball = FindBall()
    if not root or not ball then return end

    local dist = (ball.Position - root.Position).Magnitude
    if dist > Settings.HitboxSize.X then return end

    local char = LocalPlayer.Character
    if not char then return end

    local parts = {
        root,
        char:FindFirstChild("Torso"),
        char:FindFirstChild("UpperTorso"),
        char:FindFirstChild("LowerTorso"),
        char:FindFirstChild("LeftFoot"),
        char:FindFirstChild("RightFoot"),
        char:FindFirstChild("LeftLeg"),
        char:FindFirstChild("RightLeg"),
    }
    for _, part in ipairs(parts) do
        if part then
            pcall(firetouchinterest, part, ball, 0)
            pcall(firetouchinterest, part, ball, 1)
        end
    end
end

