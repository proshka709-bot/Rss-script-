end

-- [BUG FIX v4.1] FindBall: мяч находится ВНУТРИ персонажа (Workspace.LumoX_37.ball)
-- когда игрок владеет мячом. Кэш сбрасывается каждые 1 сек (было 2).
local function FindBall()
    local now = tick()
    if cachedBall and cachedBall.Parent and (now - cachedBallTime) < 1 then
        return cachedBall
    end
    -- Сначала ищем свободный мяч в корне Workspace
    local b = Workspace:FindFirstChild("ball")
    if b and b:IsA("BasePart") then
        cachedBall = b; cachedBallTime = now; return b
    end
    -- Мяч у игрока — ищем рекурсивно по всем именам
    for _, name in ipairs(BALL_NAMES) do
        local found = Workspace:FindFirstChild(name, true)
        if found and found:IsA("BasePart") then
            cachedBall = found; cachedBallTime = now; return found
        end
    end
    cachedBall = nil
    return nil
end

-- [НОВОЕ v4.1] Вспомогательные функции для чтения состояния мяча из игры
-- Игра сама выставляет эти значения — надёжнее порогов скорости

local function GetBallShot(ball)
    -- ball.Shot = true когда игрок реально ударил (не дриблинг)
    local v = ball:FindFirstChild("Shot")
    return v and v:IsA("BoolValue") and v.Value == true
end

local function GetBallCanSave(ball)
    -- ball.canSave = true когда вратарь может отбить мяч
    local v = ball:FindFirstChild("canSave")
    if v and v:IsA("BoolValue") then return v.Value end
    return true  -- если поля нет — не блокируем
end

local function GetBallCreator(ball)
    -- ball.creator — ObjectValue с игроком который владеет мячом
    local v = ball:FindFirstChild("creator")
    if v and v:IsA("ObjectValue") then return v.Value end
    return nil
end

local function IsGameActive()
    -- Проверяем Bools.freezeplay и Bools.startgame
    local bools = Workspace:FindFirstChild("Bools")
    if not bools then return true end
    local freeze  = bools:FindFirstChild("freezeplay")
    local started = bools:FindFirstChild("startgame")
    if freeze  and freeze.Value  == true  then return false end
    if started and started.Value == false then return false end
    return true
end

local function GetPing()
    if not Settings.PingCompensation then return 0 end
    local success, ping = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    end)
    return success and (math.clamp(ping, 0, 300) / 1000) or 0.05
end

