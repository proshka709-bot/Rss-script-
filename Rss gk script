-- [BUG FIX] Раньше GetBallPos искал только "ball" — не находил другие имена мяча.
-- Теперь использует FindBall() с полным списком имён.
local function StartBallTracking()
    if BallTrackConn then BallTrackConn:Disconnect() end
    BallTrackConn = RunService.Heartbeat:Connect(function()
        if not TrackBody and not TrackCamera then return end
        local ball = FindBall()  -- ИСПРАВЛЕНО: было FindFirstChild("ball", true)
        if not ball then return end
        local ballPos = ball.Position

        if TrackBody then
            local root = GetRoot()
            if root then
                local dir = (ballPos - root.Position) * Vector3.new(1, 0, 1)
                if dir.Magnitude > 0.5 then
                    root.CFrame = CFrame.new(root.Position, root.Position + dir)
                end
            end
        end

        if TrackCamera then
            pcall(function()
                local root = GetRoot()
                if not root then return end
                local camPos = root.Position + Vector3.new(0, 8, 0)
                    - (ballPos - root.Position).Unit * 18
                Camera.CFrame = CFrame.new(camPos, ballPos)
            end)
        end
    end)
end

local function StopBallTracking()
    if BallTrackConn then BallTrackConn:Disconnect(); BallTrackConn = nil end
    pcall(function() Camera.CameraType = Enum.CameraType.Custom end)
end

