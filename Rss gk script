            pcall(function() writefile(LANG_FILE, "UA") end)
            CrimsonLib.Notify({ Title = L("set_lang"), Content = T.UA.set_lang_restart, Duration = 4 })
        end
    end
})

SettingsTab:Button({
    Title    = L("set_server"),
    Desc     = L("set_server_desc"),
    Callback = function()
        CrimsonLib.Notify({ Title = "Смена сервера", Content = "Ищу сервер...", Duration = 3 })
        local placeId = game.PlaceId
        pcall(function()
            local url = ("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100"):format(placeId)
            local ok, res = pcall(function() return game:HttpGet(url) end)
            if not ok or not res then
                TeleportService:Teleport(placeId, LocalPlayer); return
            end
            local ok2, data = pcall(function() return HttpService:JSONDecode(res) end)
            if not ok2 or not data or not data.data then
                TeleportService:Teleport(placeId, LocalPlayer); return
            end
            local servers = {}
            for _, s in ipairs(data.data) do
                if s.id ~= game.JobId and s.playing < s.maxPlayers then
                    table.insert(servers, s)
                end
            end
            if #servers == 0 then
                TeleportService:Teleport(placeId, LocalPlayer); return
            end
            local chosen = servers[math.random(1, #servers)]
            TeleportService:TeleportToPlaceInstance(placeId, chosen.id, LocalPlayer)
        end)
    end
})
