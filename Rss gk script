local PassSettings = {
    Enabled     = false,
    MaxDistance = 50,
    MinDistance = 5,
    PreferOpen  = true,
    OpenRadius  = 8,
}

local lastPassTime = 0
local AutoPassConn = nil

-- [УЛУЧШЕНИЕ] FindBestTeammate: предсказываем позицию напарника через 0.3 сек
-- Раньше брали текущую позицию — теперь целимся куда напарник придёт
local function FindBestTeammate()
    local root = GetRoot()
    if not root then return nil end
    local best, bestScore = nil, math.huge
    local myTeam = LocalPlayer.Team

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        if myTeam and player.Team ~= myTeam then continue end
        local er = player.Character:FindFirstChild("HumanoidRootPart")
        if not er then continue end

        -- Предсказываем позицию напарника через ~0.3 сек (время полёта паса)
        local predPos = er.Position
        pcall(function()
            local teamVel = er.AssemblyLinearVelocity
            if teamVel.Magnitude > 0.5 then
                predPos = er.Position + teamVel * 0.3
            end
        end)

        local dist = (predPos - root.Position).Magnitude
        if dist < PassSettings.MinDistance or dist > PassSettings.MaxDistance then continue end

        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local enemyNearby = 0
        if PassSettings.PreferOpen then
            for _, enemy in ipairs(Players:GetPlayers()) do
                if enemy == LocalPlayer or enemy == player then continue end
                if enemy.Team == LocalPlayer.Team then continue end
                if not enemy.Character then continue end
                local er2 = enemy.Character:FindFirstChild("HumanoidRootPart")
                if er2 and (er2.Position - er.Position).Magnitude < PassSettings.OpenRadius then
                    enemyNearby += 1
                end
            end
        end

        local score = dist + enemyNearby * 20
        if score < bestScore then bestScore = score; best = player end
    end
    return best
end

local function DoPass(teammate)
    local root = GetRoot()
    if not root or not teammate or not teammate.Character then return end
    local er = teammate.Character:FindFirstChild("HumanoidRootPart")
    if not er then return end

    -- Целимся в предсказанную позицию напарника
    local predPos = er.Position
    pcall(function()
        local teamVel = er.AssemblyLinearVelocity
        if teamVel.Magnitude > 0.5 then
            predPos = er.Position + teamVel * 0.3
        end
    end)

    local dir = (predPos - root.Position).Unit
    root.CFrame = CFrame.new(root.Position, root.Position + Vector3.new(dir.X, 0, dir.Z))
    task.wait(0.05)
    FireButton("Pass")
end

local function StartAutoPass()
    if AutoPassConn then AutoPassConn:Disconnect() end
    AutoPassConn = RunService.Heartbeat:Connect(function()
        if not PassSettings.Enabled then return end
        local root = GetRoot()
        local ball = FindBall()
        if not root or not ball then return end
        if (ball.Position - root.Position).Magnitude > 6 then return end
        local now = tick()
        -- [УЛУЧШЕНИЕ] Джиттер ±12% на кулдаун паса — анти-бан
        if now - lastPassTime < Jitter(2.0) then return end
        local teammate = FindBestTeammate()
        if not teammate then return end
        lastPassTime = now
        DoPass(teammate)
    end)
end

