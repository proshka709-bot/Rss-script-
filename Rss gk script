local function TriggerDive(direction, isHigh)
    if direction == "Left" then
        if isHigh and Settings.DiveAutoJump then DoJump() end  -- ИСПРАВЛЕНО
        FireButton("LeftDive")
    elseif direction == "Right" then
        if isHigh and Settings.DiveAutoJump then DoJump() end  -- ИСПРАВЛЕНО
        FireButton("RightDive")
    elseif direction == "Front" then
        FireButton("FrontDive")
    elseif direction == "Jump" then
        if Settings.DiveAutoJump then DoJump() end             -- ИСПРАВЛЕНО
    end
end

local function StartAutoDive()
    if DiveConn then DiveConn:Disconnect(); DiveConn = nil end

    DiveConn = RunService.Heartbeat:Connect(function()
        local hrp = GetRoot()
        local ball = FindBall()
        if not hrp or not ball then return end

        -- [BUG FIX v4.1] Проверяем что игра активна (не заморожена)
        if not IsGameActive() then return end

        -- [BUG FIX v4.1] ball.Shot = true только при реальном ударе по воротам
        -- Без этой проверки скрипт дайвил на дриблинг, пасы и т.д.
        if not GetBallShot(ball) then return end

        -- [BUG FIX v4.1] ball.canSave = false значит вратарь не может взять мяч
        if not GetBallCanSave(ball) then return end

        -- [BUG FIX v4.1] Не дайвим если creator — наш союзник (наш удар/пас)
        local creator = GetBallCreator(ball)
        if creator and creator == LocalPlayer then return end
        if creator then
            local myTeam = LocalPlayer.Team
            if myTeam and creator.Team == myTeam then return end
        end

        local distance = (ball.Position - hrp.Position).Magnitude
        if distance > Settings.DiveMaxDistance then return end

        local vel = ball.AssemblyLinearVelocity
        local speed = vel.Magnitude

        -- [УЛУЧШЕНИЕ v4.2] Очень близкий мяч (< 8 стад) — пропускаем проверку скорости
        -- (уже поздно ждать — дайвим немедленно)
        local skipSpeedCheck = distance < 8
        if not skipSpeedCheck then
            local speedMin = distance < 12 and 18 or 30
            if speed < speedMin then return end
        end

        -- [УЛУЧШЕНИЕ v4.2] Порог направления повышен 0.25 → 0.40
        -- Меньше ложных дайвов на мячи идущие мимо ворот
        local toPlayer = (hrp.Position - ball.Position).Unit
        if toPlayer:Dot(vel.Unit) < 0.40 then return end

        local timeToImpact = distance / math.max(speed, 1)
        local extraWindow  = distance > 25 and 0.15 or 0

        -- [УЛУЧШЕНИЕ] Джиттер ±12% на окно реакции — анти-бан
        local reactionWindow = Jitter(Settings.DiveReactionTime) + GetPing() + extraWindow
        if timeToImpact > reactionWindow then return end

        local now = tick()
        -- [УЛУЧШЕНИЕ] Джиттер ±12% на кулдаун — анти-бан
        local baseCooldown = distance < 12 and 0.15 or 0.3
        local cooldown     = Jitter(baseCooldown)
        if now - lastDiveTime < cooldown then return end
        lastDiveTime = now

        local gravity      = Vector3.new(0, -Workspace.Gravity, 0)
        local predictedPos = ball.Position
            + vel * timeToImpact
            + 0.5 * gravity * timeToImpact * timeToImpact

        -- Компенсация спина (эффект Магнуса)
        local angVel = ball.AssemblyAngularVelocity
        if angVel and angVel.Magnitude > 1 then
            local spinDrift = angVel:Cross(vel) * (0.012 * timeToImpact * timeToImpact)
            predictedPos = predictedPos + spinDrift
        end

        local hrpRight = hrp.CFrame.RightVector
        local hrpUp    = hrp.CFrame.UpVector
        local toTarget = predictedPos - hrp.Position

        local sideX  = toTarget:Dot(hrpRight)
        -- [УЛУЧШЕНИЕ v4.2] Высоту определяем по ПРЕДСКАЗАННОЙ позиции мяча (Y),
        -- а не по текущей. Это точнее: мяч летит по дуге вверх/вниз.
        local predictedY = predictedPos.Y - hrp.Position.Y
        local isHigh   = predictedY > 2.0 or toTarget:Dot(hrpUp) > 2.5

        -- [УЛУЧШЕНИЕ v4.2] Центральная зона расширена 0.8 → 1.2
        -- Мячи чуть левее/правее центра идут на FrontDive, а не на боковой
        if sideX < -1.2 then
            TriggerDive("Left", isHigh)
        elseif sideX > 1.2 then
            TriggerDive("Right", isHigh)
        elseif isHigh then
            TriggerDive("Jump", false)
        else
            TriggerDive("Front", false)
        end
    end)
end

