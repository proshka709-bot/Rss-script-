            TrkBg.BackgroundColor3=C.SLIDER_TRK;TrkBg.BorderSizePixel=0;TrkBg.ZIndex=14;TrkBg.Parent=Row;_Cor(TrkBg,2)

            local Fill=Instance.new("Frame");Fill.Size=UDim2.new(0,0,1,0);Fill.BackgroundColor3=C.SLIDER_FLL
            Fill.BorderSizePixel=0;Fill.ZIndex=15;Fill.Parent=TrkBg;_Cor(Fill,2)

            local Thumb=Instance.new("Frame");Thumb.Size=UDim2.new(0,12,0,12);Thumb.Position=UDim2.new(0,-6,0.5,-6)
            Thumb.BackgroundColor3=C.TEXT_H;Thumb.BorderSizePixel=0;Thumb.ZIndex=16;Thumb.Parent=TrkBg;_Cor(Thumb,6)

            local function SetVal(v)
                v=math.clamp(v,vMin,vMax)
                -- округление до step
                local steps=math.round((v-vMin)/vStep)
                v=vMin+steps*vStep
                -- форматирование
                if vStep<1 then
                    local dec=math.ceil(-math.log10(vStep+0.0001))
                    curVal=tonumber(string.format("%."..dec.."f",v))
                else
                    curVal=math.floor(v+0.5)
                end
                local pct=(curVal-vMin)/(vMax-vMin)
                Fill.Size=UDim2.new(pct,0,1,0)
                Thumb.Position=UDim2.new(pct,-6,0.5,-6)
                RV.Text=tostring(curVal)
                if sc.Callback then pcall(sc.Callback,curVal) end
            end

            SetVal(vDef)

            -- Dragging по треку (mouse + touch)
            local dragging=false
            local function CalcFromX(absX)
                local tp=TrkBg.AbsolutePosition.X;local ts=TrkBg.AbsoluteSize.X
                local pct=math.clamp((absX-tp)/ts,0,1)
                SetVal(vMin+pct*(vMax-vMin))
            end
            TrkBg.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    dragging=true;CalcFromX(i.Position.X)
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if not dragging then return end
                if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
                    CalcFromX(i.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    dragging=false
                end
            end)
        end

        -- ════════════════════════════════════════════════════
