-- НАПАДАЮЩИЙ — AUTO FUNCTIONS
-- ============================================================

local PlayerSettings = {
    AutoShootDistance   = 15,
    AutoShootPower      = true,
    AutoDekeDistance    = 8,
    AutoTackleDistance  = 6,
}

if _savedConfig then
    if _savedConfig.AutoShootDistance  then PlayerSettings.AutoShootDistance  = _savedConfig.AutoShootDistance  end
    if _savedConfig.AutoShootPower     ~= nil then PlayerSettings.AutoShootPower = _savedConfig.AutoShootPower  end
    if _savedConfig.AutoDekeDistance   then PlayerSettings.AutoDekeDistance   = _savedConfig.AutoDekeDistance   end
    if _savedConfig.AutoTackleDistance then PlayerSettings.AutoTackleDistance = _savedConfig.AutoTackleDistance end
end

local lastShootTime  = 0
local lastDekeTime   = 0
local lastTackleTime = 0
local AutoShootConn  = nil
local AutoDekeConn   = nil
local AutoTackleConn = nil

local function GetMySide()
    local bools = Workspace:FindFirstChild("Bools")
    if bools then
        local hpg = bools:FindFirstChild("HPG")
        local apg = bools:FindFirstChild("APG")
        if hpg and hpg.Value == LocalPlayer then return "Home" end
        if apg and apg.Value == LocalPlayer then return "Away" end
    end
    local root = GetRoot()
    if not root then return nil end
    local homeSpawn = Workspace:FindFirstChild("HomeGKSpawn")
    local awaySpawn = Workspace:FindFirstChild("AwayGKSpawn")
    if not homeSpawn or not awaySpawn then return nil end
    if (homeSpawn.Position - root.Position).Magnitude <
       (awaySpawn.Position - root.Position).Magnitude then
        return "Home"
    else
        return "Away"
    end
end

local function GetEnemyGoalPos()
    local root = GetRoot()
    if not root then return nil end

    local homeGoalDet = Workspace:FindFirstChild("HomeGoalDetector")
    local awayGoalDet = Workspace:FindFirstChild("AwayGoalDetector")
    local homeGKSpawn = Workspace:FindFirstChild("HomeGKSpawn")
    local awayGKSpawn = Workspace:FindFirstChild("AwayGKSpawn")

    local isHome = false
    if homeGKSpawn and awayGKSpawn then
        isHome = (homeGKSpawn.Position - root.Position).Magnitude <
                 (awayGKSpawn.Position - root.Position).Magnitude
    end

    local enemyDet = isHome and awayGoalDet or homeGoalDet
    if enemyDet then return enemyDet.Position end

    local homeGoal = Workspace:FindFirstChild("HomeGoal")
    local awayGoal = Workspace:FindFirstChild("AwayGoal")
    local enemyGoal = isHome and awayGoal or homeGoal
    if enemyGoal then
        local ok, p = pcall(function() return enemyGoal:GetModelCFrame().Position end)
        if ok then return p end
    end

    return nil
end

local function StartAutoShoot()
    if AutoShootConn then AutoShootConn:Disconnect() end
    AutoShootConn = RunService.Heartbeat:Connect(function()
        local root = GetRoot()
        local ball = FindBall()
        if not root or not ball then return end

        -- [УЛУЧШЕНИЕ v4.1] Не бить если игра заморожена (freezeplay/startgame)
        if not IsGameActive() then return end

        local dist = (ball.Position - root.Position).Magnitude
        if dist > PlayerSettings.AutoShootDistance then return end

        local goalPos = GetEnemyGoalPos()
        if not goalPos then return end

        -- [BUG FIX] Раньше всегда брал HomeGoalDetector независимо от стороны.
        -- Теперь правильно определяем НАШИ ворота через GetMySide()
        local vel = ball.AssemblyLinearVelocity
        if vel.Magnitude > 5 then
            local side = GetMySide()
            local ourGoalDet = side == "Home"
                and Workspace:FindFirstChild("HomeGoalDetector")
                or  Workspace:FindFirstChild("AwayGoalDetector")
            if ourGoalDet then
                local toOurGoal = (ourGoalDet.Position - ball.Position).Unit
                if toOurGoal:Dot(vel.Unit) > 0.7 then return end
            end
        end

        local now = tick()
        -- [УЛУЧШЕНИЕ] Джиттер ±12% на кулдаун удара — анти-бан
        if now - lastShootTime < Jitter(1.0) then return end
        lastShootTime = now

        -- [УЛУЧШЕНИЕ] Плавный float-оффсет вместо целочисленного random
        local offsetX = (math.random() * 2 - 1) * 4
        local aimPos  = goalPos + Vector3.new(offsetX, 0, 0)
        root.CFrame = CFrame.new(root.Position, Vector3.new(aimPos.X, root.Position.Y, aimPos.Z))
        task.wait(0.05)

        local distToGoal = (goalPos - root.Position).Magnitude
        local usePower   = distToGoal > 20 or PlayerSettings.AutoShootPower

        if usePower then FireButton("PowerShoot")
        else             FireButton("Shoot") end
    end)
end

local function StartAutoDeke()
    if AutoDekeConn then AutoDekeConn:Disconnect() end
    AutoDekeConn = RunService.Heartbeat:Connect(function()
        local root = GetRoot()
        local ball = FindBall()
        if not root or not ball then return end

        local distToBall = (ball.Position - root.Position).Magnitude
        if distToBall > 4 then return end

        local nearEnemy = false
        local myTeam = LocalPlayer.Team
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if not player.Character then continue end
            if myTeam and player.Team == myTeam then continue end
            local enemyRoot = player.Character:FindFirstChild("HumanoidRootPart")
            if enemyRoot then
                local d = (enemyRoot.Position - root.Position).Magnitude
                if d < PlayerSettings.AutoDekeDistance then
                    nearEnemy = true; break
                end
            end
        end

        if not nearEnemy then return end

        local now = tick()
        -- [УЛУЧШЕНИЕ] Джиттер ±12% — анти-бан
        if now - lastDekeTime < Jitter(1.5) then return end
        lastDekeTime = now

        FireButton("Deke")
    end)
end

local function StartAutoTackle()
    if AutoTackleConn then AutoTackleConn:Disconnect() end
    AutoTackleConn = RunService.Heartbeat:Connect(function()
        local root = GetRoot()
        local ball = FindBall()
        if not root or not ball then return end

        local distToBall = (ball.Position - root.Position).Magnitude
        if distToBall < 5 then return end

        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local myTeam = LocalPlayer.Team
                if myTeam and player.Team == myTeam then continue end  -- не подкатывать союзников
                local enemyRoot = player.Character:FindFirstChild("HumanoidRootPart")
                if enemyRoot then
                    local distToEnemy   = (enemyRoot.Position - root.Position).Magnitude
                    local enemyDistBall = (ball.Position - enemyRoot.Position).Magnitude

                    if distToEnemy < PlayerSettings.AutoTackleDistance and enemyDistBall < 6 then
                        local now = tick()
                        -- [УЛУЧШЕНИЕ] Джиттер ±12% — анти-бан
                        if now - lastTackleTime < Jitter(2.0) then return end
                        lastTackleTime = now
                        FireButton("Tackle")
                        break
                    end
                end
            end
        end
    end)
end

