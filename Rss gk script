end

local function DoPenaltyChoice()
    local dir = PenaltyDirection
    -- [КРИТИЧЕСКИЙ БАГ FIX v4.1]
    -- Сканирование игры показало: кнопки пенальти называются Left, Center, Right
    -- (parent='PenaltyShoot'), а НЕ LeftDive/RightDive/FrontDive!
    -- Старый скрипт НИКОГДА не находил эти кнопки и пенальти не срабатывало.
    local btnName
    if dir == "Random" then
        local choices = {"Left", "Center", "Right"}
        btnName = choices[math.random(1, 3)]
    elseif dir == "Left"  then btnName = "Left"
    elseif dir == "Right" then btnName = "Right"
    elseif dir == "Front" then btnName = "Center"
    else btnName = "Left"
    end

    local ok = PressButton(btnName)
    if ok then
        CrimsonLib.Notify({
            Title   = "Пенальти",
            Content = "✅ Выбрал: " .. btnName,
            Duration = 3,
        })
    end
end

local function StartPenaltyWatcher()
    if PenaltyConn then PenaltyConn:Disconnect() end
    PenaltyDone = false

    local bools = Workspace:FindFirstChild("Bools")
    if not bools then return end

    local penaltyVal  = bools:FindFirstChild("Penalty")
    local shootoutVal = bools:FindFirstChild("PenaltyShootout")
    local waitStart   = nil

    PenaltyConn = RunService.Heartbeat:Connect(function()
        if not PenaltyEnabled then return end

        local isPenalty = (penaltyVal and penaltyVal.Value)
            or (shootoutVal and shootoutVal.Value)

        if isPenalty then
            local leftBtn  = FindDiveButton("LeftDive")
            local rightBtn = FindDiveButton("RightDive")
            local frontBtn = FindDiveButton("FrontDive")

            local buttonsVisible = leftBtn or rightBtn or frontBtn

            if buttonsVisible and not PenaltyDone then
                if not waitStart then
                    waitStart = tick()
                    CrimsonLib.Notify({
                        Title   = "Пенальти!",
                        Content = "Жду " .. PenaltyWaitTime .. " сек...",
                        Duration = PenaltyWaitTime,
                    })
                end

                if tick() - waitStart >= PenaltyWaitTime then
                    PenaltyDone = true
                    DoPenaltyChoice()
                end
            end
        else
            if PenaltyDone or waitStart then
                PenaltyDone = false
                waitStart   = nil
            end
        end
    end)
end

local function StopPenaltyWatcher()
    if PenaltyConn then PenaltyConn:Disconnect(); PenaltyConn = nil end
end

