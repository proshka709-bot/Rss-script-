-- ============================================================
-- [УЛУЧШЕНИЕ] АНТИ-БАН: джиттер на таймеры
-- Добавляет случайное отклонение ±pct% к любому значению времени
-- Это делает поведение скрипта менее машинным / паттерн-предсказуемым
-- ============================================================
local function Jitter(base, pct)
    pct = pct or 0.12  -- 12% отклонение по умолчанию
    local delta = base * pct
    return base + (math.random() * 2 - 1) * delta
end

